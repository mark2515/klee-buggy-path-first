array a[4] : w32 -> w8 = symbolic
array b[4] : w32 -> w8 = symbolic
array c[4] : w32 -> w8 = symbolic
array d[4] : w32 -> w8 = symbolic
(query [(Slt 10
              N0:(ReadLSB w32 0 a))
         (Slt 20
              N1:(ReadLSB w32 0 b))
         (Slt 30
              N2:(ReadLSB w32 0 c))
         (Slt 40
              N3:(ReadLSB w32 0 d))
         (Eq 0
             (SRem w32 (Add w32 N0 (Mul w32 N1 N2))
                       7))
         (Eq 0
             (SRem w32 (Sub w32 N1 N3) 5))
         (Eq 0
             (SRem w32 (Mul w32 N2 N3) 3))
         (Eq 0
             (Mul w32 (Mul w32 (Mul w32 N0 N1) N2)
                      N3))]
        false)
