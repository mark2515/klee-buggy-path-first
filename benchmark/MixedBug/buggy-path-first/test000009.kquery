array a[4] : w32 -> w8 = symbolic
array b[4] : w32 -> w8 = symbolic
array c[4] : w32 -> w8 = symbolic
array d[4] : w32 -> w8 = symbolic
(query [(Slt 20
              N0:(ReadLSB w32 0 b))
         (Slt 30
              N1:(ReadLSB w32 0 c))
         (Slt 40
              N2:(ReadLSB w32 0 d))
         (Eq 0
             (SRem w32 (Add w32 42 (Mul w32 N0 N1))
                       7))
         (Eq 0
             (SRem w32 (Sub w32 N0 N2) 5))
         (Eq 0
             (SRem w32 (Mul w32 N1 N2) 3))
         (Eq false
             (Eq 0
                 (Mul w32 (Mul w32 (Mul w32 42 N0) N1)
                          N2)))
         (Slt 100 (Xor w32 42 N0))
         (Eq false
             (Slt (Or w32 N1 N2) 50))
         (Eq 42
             (ReadLSB w32 0 a))
         (Eq N0 N1)]
        false)
