array a[4] : w32 -> w8 = symbolic
array b[4] : w32 -> w8 = symbolic
array c[4] : w32 -> w8 = symbolic
array d[4] : w32 -> w8 = symbolic
(query [(Eq false
             (Slt 10
                  N0:(ReadLSB w32 0 a)))
         (Sle 0 N0)
         (Slt N0 10)
         (Slt 5
              N1:(ReadLSB w32 0 b))
         (Eq 100
             (ReadLSB w32 0 c))
         (Slt N2:(ReadLSB w32 0 d)
              0)
         (Eq false
             (Sle 0
                  N3:(Add w32 100
                              (Add w32 (Add w32 N0 N1) N2))))
         (Eq false
             (Ult (Add w64 8589934592
                           (Mul w64 4 (SExt w64 N3)))
                  5))]
        false)
