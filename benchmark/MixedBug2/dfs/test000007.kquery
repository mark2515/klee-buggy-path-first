array a[4] : w32 -> w8 = symbolic
array b[4] : w32 -> w8 = symbolic
array c[4] : w32 -> w8 = symbolic
(query [(Eq false
             (Slt 0
                  N0:(ReadLSB w32 0 a)))
         (Slt 50
              N1:(ReadLSB w32 0 b))
         (Eq false
             (Sle 0
                  (SRem w32 (Add w32 (Add w32 N0 N1)
                                     N2:(ReadLSB w32 0 c))
                            20)))
         (Eq 0
             (SRem w32 (Add w32 (Mul w32 N0 N1) N2)
                       7))
         (Eq 0
             (SRem w32 (Sub w32 N1 N2) 5))]
        false)
