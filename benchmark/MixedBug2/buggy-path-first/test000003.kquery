array a[4] : w32 -> w8 = symbolic
array b[4] : w32 -> w8 = symbolic
array c[4] : w32 -> w8 = symbolic
(query [(Slt 0
              N0:(ReadLSB w32 0 a))
         (Slt 10 N0)
         (Slt 20 N0)
         (Slt 30 N0)
         (Slt 50
              N1:(ReadLSB w32 0 b))
         (Sle 0
              N2:(SRem w32 (Add w32 (Add w32 N0 N1)
                                    N3:(ReadLSB w32 0 c))
                           20))
         (Eq false (Slt N2 4))
         (Eq 0
             (SRem w32 (Add w32 (Mul w32 N0 N1) N3)
                       7))
         (Eq 0
             (SRem w32 (Sub w32 N1 N3) 5))]
        false)
