array x[4] : w32 -> w8 = symbolic
(query [(Slt 100
              N0:(ReadLSB w32 0 x))
         (Eq 0 (SRem w32 N0 2))
         (Eq 0 (SRem w32 N0 3))
         (Eq 0 (SRem w32 N0 5))
         (Eq 0 (SRem w32 N0 7))
         (Eq 0 (SRem w32 N0 11))
         (Eq 0 (SRem w32 N0 13))
         (Eq 0 (SRem w32 N0 17))]
        false)
